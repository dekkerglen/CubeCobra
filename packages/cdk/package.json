{
  "name": "@cubecobra/cdk",
  "version": "0.1.0",
  "bin": {
    "infra": "app/infra.js",
    "bootstrap": "app/bootstrap.js",
    "pipeline": "app/pipeline.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "cdk:local": "cdklocal bootstrap --context environment=local --context version=1.0.0 && cdklocal deploy --context environment=local --context version=1.0.0",
    "deploy:pipeline": "npm run build && cdk deploy CubeCobraPipelineStack --app 'node app/pipeline.js'",
    "test:ci": "npx jest --coverage --coverageReporters text"
  },
  "type": "commonjs",
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.14",
    "@types/node": "22.7.9",
    "aws-cdk": "^2.1113.0",
    "jest": "^29.7.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "aws-cdk-lib": "2.246.0",
    "aws-cdk-local": "^3.0.1",
    "constructs": "^10.0.0",
    "dotenv": "^16.0.0",
    "source-map-support": "^0.5.21"
  }
}
