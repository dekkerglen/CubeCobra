{
  "name": "@cubecobra/annotator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Oriented name-bar annotation tool for training the deck-photo card-name detector.",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dataset:bulk": "node scripts/download-bulk.mjs",
    "dataset:generate": "node scripts/generate-dataset.mjs",
    "model:dataset": ".venv/bin/python training/export_dataset.py",
    "model:train": ".venv/bin/python training/train.py",
    "model:predict": ".venv/bin/python training/predict.py",
    "model:export": ".venv/bin/python training/export_web.py"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
