{
  "name": "@cubecobra/jobs",
  "version": "1.0.0",
  "scripts": {
    "init-data": "node dist/jobs/src/init-data.js",
    "update-draft-history": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/update_draft_history.js",
    "update-cube-history": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/update_cube_history.js",
    "update-metadata-dict": "NODE_OPTIONS=--max_old_space_size=36864 node dist/jobs/src/update_metadata_dict.js",
    "update-cards": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/update_cards.js",
    "sync-card-images": "node dist/jobs/src/sync_card_images.js",
    "update-combos": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/update_combos.js",
    "repair-cube-hashes": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/repairCubeHashes.js --",
    "repair-package-hashes": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/repairPackageHashes.js --",
    "export-cubes": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/export_cubes.js",
    "export-decks": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/export_decks.js",
    "export-simple-card-dict": "NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/export_simple_card_dict.js",
    "export-all": "npm run init-data && npm run export-cubes && npm run export-decks && npm run export-simple-card-dict",
    "apply-migrations": "npm run init-data && NODE_OPTIONS=--max_old_space_size=28672 node dist/jobs/src/apply_scryfall_migrations.js",
    "dev:update-draft-history": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/update_draft_history.ts",
    "dev:update-cube-history": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/update_cube_history.ts",
    "dev:update-metadata-dict": "NODE_OPTIONS=--max_old_space_size=36864 tsx src/update_metadata_dict.ts",
    "dev:update-cards": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/update_cards.ts",
    "dev:sync-card-images": "tsx src/sync_card_images.ts",
    "dev:update-combos": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/update_combos.ts",
    "dev:repair-cube-hashes": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/repairCubeHashes.ts --",
    "dev:repair-package-hashes": "NODE_OPTIONS=--max_old_space_size=28672 tsx src/repairPackageHashes.ts --",
    "update-all": "npm run init-data && npm run update-draft-history && npm run update-cube-history && npm run update-metadata-dict && npm run update-cards",
    "update-cards-daily": "npm run init-data && npm run update-cards",
    "update-metadata-weekly": "npm run init-data && npm run update-draft-history && npm run update-cube-history && npm run update-metadata-dict",
    "fix-external-paths": "npx tsc-alias -p tsconfig.json",
    "build": "npx tsc && npm run fix-external-paths",
    "clean": "rm -rf dist/ node_modules/",
    "test": "npx jest",
    "test:ci": "npx jest --collectCoverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.927.0",
    "@aws-sdk/credential-providers": "^3.926.0",
    "@aws-sdk/lib-storage": "^3.927.0",
    "dotenv": "^16.0.0",
    "event-stream": "^4.0.1",
    "hnswlib-node": "^3.0.0",
    "jsonparse": "^1.3.1",
    "JSONStream": "^1.3.5",
    "lodash": "^4.17.21",
    "module-alias": "^2.2.3",
    "node-fetch": "^2.7.0",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.11",
    "jest": "^29.7.0",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "_moduleAliases": {
    "@server": "../server/src",
    "@utils": "../utils/src",
    "serverutils": "../server/src/serverutils",
    "dynamo": "../server/src/dynamo",
    "routes": "../server/src/routes"
  }
}
